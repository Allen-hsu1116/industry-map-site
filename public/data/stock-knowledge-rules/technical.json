      "id": "technical.wyckoff-accumulation",
      "category": "technical",
      "title": "區間吸籌與派發辨識",
      "principle": "盤整區間內需觀察量價關係，低檔量縮不破與突破放量偏吸籌，高檔爆量不漲偏派發。",
      "positiveSignals": [
        "低檔區間量縮守穩",
        "突破區間上緣放量",
        "回測區間上緣不破"
      ],
      "negativeSignals": [
        "高檔爆量收黑",
        "跌破區間下緣",
        "反彈量縮無法站回"
      ],
      "scoringImpact": {
        "positive": 14,
        "negative": -18
      },
      "riskControls": [
        "區間未突破前以觀察為主，避免預設方向"
      ],
