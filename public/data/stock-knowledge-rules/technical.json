      "principle": "均線、量能、型態與相對強弱同向時才提高技術分數，單一指標背離時應降權。",
      "positiveSignals": [
        "均線多頭排列且量能擴增",
        "價格創高且相對大盤轉強",
        "型態突破與籌碼買超同步"
      ],
      "negativeSignals": [
        "價格創高但量縮",
        "技術偏多但法人連賣",
        "指標互相矛盾"
      ],
      "scoringImpact": {
